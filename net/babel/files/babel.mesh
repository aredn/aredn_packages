config default 'default'
        option rxcost '96'
        option hello_interval '10'
        option update_interval '120'
        option smoothing_half_life '10'
        option rtt_decay '42'
        option rtt_min '10'
        option rtt_max '1000'
        option max_rtt_penalty '2000'

config wireless 'wireless'
        option rtt_enable 'true'
        option rxcost '256'

config wired 'wired'
        option rxcost '96'
        option split_horizon 'true'

config tunnel 'tunnel'
        option rtt_enable 'true'
        option rxcost '206'
        option rxscale '100'

config xlink 'xlink'
        option rtt_enable 'true'
        option rxcost '150'
        option rxscale '50'
