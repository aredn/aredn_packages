config default 'default'
        option rxcost '96'
        option hello_interval '4'
        option update_interval '120'
        option smoothing_half_life '10'
        option rtt_decay '42'
        option rtt_min '10'
        option rtt_max '50'
        option max_rtt_penalty '4000'

config wireless 'wireless'
        option rxcost '256'

config wired 'wired'
        option rxcost '96'
        option split_horizon 'true'

config tunnel 'tunnel'
        option rxcost '206'
        option hello_interval '10'
        option update_interval '120'
        option supernode_update_interval '300'
        option rtt_min '10'
        option rtt_max '400'
        option max_rtt_penalty '400'

config xlink 'xlink'
        option rxcost '150'
