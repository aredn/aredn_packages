#!/bin/sh

BABEL_PORT=6697
BABEL_PATH=/var/run/babel.sock

case "${ACTION}" in
    ifdown)
        socat -T 30 -t 30 - UNIX-CONNECT:${BABEL_PATH} <<__END__
flush interface ${INTERFACE}
__END__
        ;;
    ifup)
        if [ "${INTERFACE}" == "wifi" ]; then
            if [ "${DEVICE}" != "br-nomesh" ]; then
                socat -T 30 -t 30 - UNIX-CONNECT:${BABEL_PATH},interval=5,retry=12 <<__END__
flush interface ${DEVICE}
interface ${DEVICE} type wireless enable-timestamps true rxcost $(uci -q get babel.wireless.rxcost) split-horizon false
__END__
            fi
        elif [ "${INTERFACE:0:2}" = "wg" ]; then
            cost=$(uci -q get network.${INTERFACE}.cost)
            if [ "$cost" = "" ]; then
                cost=$(uci -q get babel.tunnel.rxcost)
            fi
            update_interval=$(uci -q get babel.tunnel.update_interval)
            if [ "$(uci -q get aredn.@supernode[0].enable)" = "1" ]; then
                update_interval=$(uci -q get babel.supernode.update_interval)
            fi
            socat -T 30 -t 30 - UNIX-CONNECT:${BABEL_PATH},interval=5,retry=12 <<__END__
flush interface ${DEVICE}
interface ${DEVICE} type tunnel rxcost ${cost} hello-interval $(uci -q get babel.tunnel.hello_interval) update-interval ${update_interval} rtt-min $(uci -q get babel.tunnel.rtt_min) rtt-max $(uci -q get babel.tunnel.rtt_max) max-rtt-penalty $(uci -q get babel.tunnel.max_rtt_penalty)
redistribute anyproto if ${DEVICE} deny
__END__
        elif [ "${INTERFACE:0:5}" = "xlink" ]; then
            cost=$(uci -q get network.${INTERFACE}.cost)
            if [ "$cost" = "" ]; then
                cost=$(uci -q get babel.xlink.rxcost)
            fi
            socat - UNIX-CONNECT:${BABEL_PATH},interval=5,retry=12 <<__END__
flush interface ${DEVICE}
interface ${DEVICE} type wireless rxcost ${cost}
redistribute anyproto if ${DEVICE} deny
__END__
        fi
        ;;
    *)
        ;;
esac
