const DEBUG = false;

const VERSION = "0.0.1";

import * as fs from "fs";
import * as socket from "socket";
import * as uci from "uci";
import * as babel from "aredn.babel";

//
// Events
//
const POLLIN                = socket.POLLIN;
const POLLOUT               = socket.POLLOUT;
const POLLRDHUP             = socket.POLLRDHUP;
const POLLTIMER             = 0x10000;
const NOINTERFACE           = 0x20000;
const NEWADDRESS            = 0x40000;
const CLOSECONN             = 0x80000;
//
// Commands
//
const CMD_VERSION           = ord('V');
const CMD_UPDATE_NAMES      = ord('N');
const CMD_UPDATE_SERVICES   = ord('U');
const CMD_SYNC              = ord('S');
//
// Poll timers
//
const NEIGHBORHOOD_POLL     = 60;
const IDLE_POLL             = 60 * 60;
const ROUTE_POLL            = 30;
//
// Gray list timers
//
const GRAY_TIMEOUT          = 45;
const GRAY_MAX_SCALE        = 15;
//
// TCP configuration
//
const CHANNEL_KEEPCNT       = 3;
const CHANNEL_KEEPIDLE      = 30;
const CHANNEL_KEEPALIVE     = 30;
const CHANNEL_SYNCNT        = 3;
const CHANNEL_USER_TIMEOUT  = 60;
const CHANNEL_CONN_TIMEOUT  = 10;
//
// Communications
//
const AREDNLINK_PORT        = 9623;
const AREDNLINK_MGR         = "/var/run/arednlink.sock";
//
// DNS and services file locations.
//
const ROOT_DIR_NAMES        = "/tmp/arednlink/names/";
const ROOT_DIR_SERVICES     = "/tmp/arednlink/services/";
//
// Default hop count for messages.
//
const HOP_DEFAULT           = 64;
//
// Set of all connected channels.
//
const channels = {};
//
// Set of known interfaces
//
let interfaces = {};
//
// Neighborhood monitor
//
let neighborhood = null;
//
// Current babel host routes
//
let hostroutes = {};
//
// Greylist of addresses in timeout
//
const graylist = {};
//
// Our IPv4 address, used for all messages we generate
//
const myipv4address = uci.cursor("/etc/config.mesh").get("setup", "globals", "wifi_ip");
const myipv4iparr = iptoarr(myipv4address);

let channelId = 1;
let exiting = false;
const poller = { fn: null, len: -1 };

//
// Compare two addresses and select the best/highest one.
//
function bestAddress(a, b) {
    if (!a) {
        return b;
    }
    if (!b) {
        return a;
    }
    const aa = iptoarr(a);
    const ab = iptoarr(b);
    for (let i = 0; i < 16; i++) {
        if (aa[i] < ab[i]) {
            return b;
        }
        if (aa[i] > ab[i]) {
            return a;
        }
    }
    return a;
}

//
// Determine if this interface is a valid next hop to the ip.
//
function validNextHop(channel, ipv4address) {
    if (!ipv4address || ipv4address == myipv4address) {
        return false;
    }
    const f = fs.popen(`/sbin/ip route get ${ipv4address}`);
    if (f) {
        const hop = f.read("all");
        f.close();
        if (index(hop, `dev ${channel.interface} `) !== -1) {
            return true;
        }
    }
    return false;
}

//
// Calculate time for timer
//
function when(timeout) {
    return clock(true)[0] + timeout;
}

//
// Setup the socket just the way we want it.
//
function setupConnection(sock) {
    sock.setopt(socket.IPPROTO_TCP, socket.TCP_KEEPCNT, CHANNEL_KEEPCNT);
    sock.setopt(socket.IPPROTO_TCP, socket.TCP_KEEPIDLE, CHANNEL_KEEPIDLE);
    sock.setopt(socket.IPPROTO_TCP, socket.TCP_KEEPINTVL, CHANNEL_KEEPALIVE);
    sock.setopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1);
    sock.setopt(socket.IPPROTO_TCP, socket.TCP_SYNCNT, CHANNEL_SYNCNT);
    sock.setopt(socket.IPPROTO_TCP, socket.TCP_USER_TIMEOUT, CHANNEL_USER_TIMEOUT * 1000);
}

//
// Build a message
//
function buildMessage(cmd, ipv4addr, hop, payload) {
    DEBUG && print(`buildMessage: cmd ${cmd} ip ${ipv4addr} hop ${hop} payload ${payload}\n`);
    payload = payload ?? "";
    const len =  8 + length(payload); // Length is the entire message including the length itself.
    const addr = ipv4addr == myipv4address ? myipv4iparr : iptoarr(ipv4addr);
    if (!addr) {
        DEBUG && print(`buildMessage: bad ip address ${ipv4addr}\n`);
        return "";
    }
    return chr(len >> 8, len & 255, cmd, hop , addr[0], addr[1], addr[2], addr[3]) + payload;
}

//
// Build a targetted sync message.
//
function buildTargettedSyncMessage(target) {
    let sync = "";
    for (let ip in hostroutes) {
        if (hostroutes[ip] === target) {
            if (!(fs.access(`${ROOT_DIR_NAMES}${ip}`) && fs.access(`${ROOT_DIR_SERVICES}${ip}`))) {
                const addr = iptoarr(ip);
                sync += chr(addr[0], addr[1], addr[2], addr[3]);
            }
        }
    }
    return buildMessage(CMD_SYNC, myipv4address, 1, sync);
}

//
// Send message to all (most) of our connected channels.
//
function sendMsgToAll(msg, except) {
    for (let id in channels) {
        const channel = channels[id];
        if ((channel.state === "CONNECTED" || channel.state === "CONNECTED_INCOMING") && channel !== except) {
            channel.outgoing += msg;
            channel.polling |= POLLOUT;
        }
    }
}

//
// Setup our main socket for incoming connections, and the management socket.
//
const main = socket.create(socket.AF_INET6, socket.SOCK_STREAM);
main.setopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1);
main.bind({ address: "::", port: AREDNLINK_PORT });                             
main.listen();
fs.unlink(AREDNLINK_MGR);
const mgr = socket.listen({ path: AREDNLINK_MGR }, null, { socktype: socket.SOCK_STREAM });

//
// Process incoming message locally.
//
function processMessage(cmd, hop, srcipv4, payload)
{
    DEBUG && print(`processMessage: cmd ${cmd} hop ${hop} ip ${srcipv4} payload ${payload}\n`);
    switch (cmd) {
        case CMD_VERSION:
            if (payload != VERSION) {
                graylist[this.address] = { timer: when(GRAY_TIMEOUT * GRAY_MAX_SCALE), scale: GRAY_MAX_SCALE };
                this.process(CLOSECONN);
            }
            return false;
        case CMD_SYNC:
            // A sync request from a neighbor. Payload contains a list of addresses the neighbor is soliciting data for.
            // Return false so the request is not forwarded (it should have a hop of 1);
            const len = length(payload);
            for (let i = 0; i < len; i += 4) {
                const ip = arrtoip([ord(payload, i), ord(payload, i+1), ord(payload, i+2), ord(payload, i+3)]);
                const name = fs.readfile(`${ROOT_DIR_NAMES}${ip}`);
                if (name) {
                    this.outgoing += buildMessage(CMD_UPDATE_NAMES, ip, HOP_DEFAULT, name);
                }
                const service = fs.readfile(`${ROOT_DIR_SERVICES}${ip}`);
                if (service) {
                    this.outgoing += buildMessage(CMD_UPDATE_SERVICES, ip, HOP_DEFAULT, service);
                }
            }
            if (length(this.outgoing)) {
                this.polling |= POLLOUT;
            }
            return false;
        case CMD_UPDATE_NAMES:
        {
            // Updates the name entries published by the srvipv4 node. We read and compare so we
            // dont write to the file unless it has changed nor do we forward the update.
            const path = `${ROOT_DIR_NAMES}${srcipv4}`;
            const old = fs.readfile(path);
            if (old == payload) {
                return false;
            }
            fs.writefile(path, payload);
            return true;
        }
        case CMD_UPDATE_SERVICES:
        {
            // Updates the service entries published by the srvipv4 node. We read and compare so
            // we dont write to tjhe file unless it has changed nor do we forward the update.
            const path = `${ROOT_DIR_SERVICES}${srcipv4}`;
            const old = fs.readfile(path);
            if (old == payload) {
                return false;
            }
            fs.writefile(path, payload);
            return true;
        }
        default:
            return true;
    }
}

//
// Process incoming data from another node.
//
function processRequest() {
    DEBUG && print(`processRequest channel ${this}\n`);
    const data = this.connection.recv();
    DEBUG && print(`--- data length ${length(data)}\n`);
    if (!data || !length(data)) {
        return;
    }
    this.incoming += data;
    const ilen = length(this.incoming);
    DEBUG && print(`--- incoming length ${ilen}\n`);
    // Process the incoming data
    let i = 0;
    while (i < ilen) {
        // Make sure we have enough to read the length
        if (i + 2 > ilen) {
            break;
        }
        DEBUG && print(`--- header [ ${ord(this.incoming, i+0)}, ${ord(this.incoming, i+1)}, ${ord(this.incoming, i+2)}, ${ord(this.incoming, i+3)}, ${ord(this.incoming, i+4)}, ${ord(this.incoming, i+5)}, ${ord(this.incoming, i+6)}, ${ord(this.incoming, i+7)} ]\n`);
        const len = 256 * ord(this.incoming, i) + ord(this.incoming, i + 1);
        DEBUG && print(`--- msg length ${len}\n`);
        // Then make sure we have enough to read the packet.
        if (i + len > ilen) {
            break;
        }
        const cmd = ord(this.incoming, i + 2);
        const hop = ord(this.incoming, i + 3);
        const srcipv4 = [ ord(this.incoming, i + 4), ord(this.incoming, i + 5), ord(this.incoming, i + 6), ord(this.incoming, i + 7) ];
        const srcipv4str = arrtoip(srcipv4);
        const validhop = validNextHop(this, srcipv4str);
        DEBUG && print(`--- msg ${cmd} hop ${hop} validhop ${validhop} ${srcipv4src}\n`);
        if (validhop) {
            const payload = substr(this.incoming, i + 8, len - 8);
            const forward = call(processMessage, this, null, cmd, hop, srcipv4str, payload);
            if (forward && hop > 1) {
                // Build and forward message
                sendMsgToAll(chr(len >> 8, len & 255, cmd, hop - 1, srcipv4[0], srcipv4[1], srcipv4[2], srcipv4[3]) + payload, this);
            }
        }
        i += len;
    }
    if (i >= ilen) {
        this.incoming = "";
    }
    else {
        this.incoming = substr(this.incoming, i);
    }
}

//
// Process the current channel, potentially consuming or sending traffic on the socket
// if the event says we can.
// this: channel
//
function channelProcess(event) {
    DEBUG && print(`channelProcess: id ${this.id} event ${sprintf("%x", event)} state ${this.state} address ${this.address ?? '<none>'}\n`);
    switch (this.state) {
        case "IDLE":
        {
            switch (event) {
                case NEWADDRESS:
                    this.state = "NEW";
                    this.timer = 0;
                    break;
                case NOINTERFACE:
                case CLOSECONN:
                    this.state = "EXIT";
                    this.timer = 0;
                    break;
                case POLLTIMER:
                default:
                    this.timer = when(IDLE_POLL);
                    break;
            }
            break;
        }
        case "NEW":
        {
            switch (event) {
                case POLLTIMER:
                    if (bestAddress(this.myaddress, this.address) === this.myaddress) {
                        this.state = "IDLE";
                        this.timer = 0;
                    }
                    else {
                        DEBUG && print(`Connecting to ${this.address} on ${this.interface}\n`);
                        this.connection = socket.connect({ interface: this.interface, address: this.address, port: AREDNLINK_PORT }, null, null, CHANNEL_CONN_TIMEOUT * 1000);
                        DEBUG && print(`Connection: ${this.connection}\n`);
                        if (!this.connection) {
                            // Failed to connect
                            // Timeout address to graylist
                            const gray = graylist[this.address];
                            if (gray) {
                                gray.scale = min(gray.scale * 1.5, GRAY_MAX_SCALE);
                                gray.timer = when(GRAY_TIMEOUT * gray.scale);
                            }
                            else {
                                graylist[this.address] = { timer: when(GRAY_TIMEOUT), scale: 1 };
                            }
                            this.state = "EXIT";
                            this.timer = 0;
                        }
                        else {
                            // Setup the connection just the way we like it
                            setupConnection(this.connection);
                            // If the we successfully opened the primary, close any secondary
                            const iface = interfaces[this.interface];
                            if (iface.primary === this && iface.secondary) {
                                iface.secondary.process(CLOSECONN);
                            }
                            // No longer gray (in case were were)
                            delete graylist[this.address];
                            this.state = "CONNECTED";
                            this.polling = POLLIN|POLLOUT|POLLRDHUP;
                            this.timer = null;
                            this.incoming = "";
                            this.outgoing = buildMessage(CMD_VERSION, myipv4address, 1, VERSION) + buildTargettedSyncMessage(this.interface);
                            // If we are initiating a connection, then we should terminate any incoming connections
                            // on the same interface, as they are no longer connected to the best node.
                            for (let id in channels) {
                                const channel = channels[id];
                                if (channel.interface === this.interface && channel !== this) {
                                    channel.process(CLOSECONN);
                                }
                            }
                        }
                    }
                    break;
                case NEWADDRESS:
                case NOINTERFACE:
                case CLOSECONN:
                default:
                    this.state = "EXIT";
                    this.timer = 0;
                    break;
            }
            break;
        }
        case "CONNECTED":
        {
            switch (event) {
                case POLLIN:
                    call(processRequest, this);
                    break;
                case POLLOUT:
                case POLLIN|POLLOUT:
                    const sent = this.connection.send(this.outgoing);
                    if (sent == length(this.outgoing)) {
                        this.outgoing = "";
                        this.polling &= ~POLLOUT;
                    }
                    else if (send !== null) {
                        this.outgoing = substr(this.outgoing, sent);
                    }
                    break;
                case POLLRDHUP:
                case POLLRDHUP|POLLIN:
                case POLLRDHUP|POLLOUT:
                case POLLRDHUP|POLLIN|POLLOUT:
                    if (this.connection) {
                        this.connection.close();
                        this.connection = null;
                    }
                    this.polling = 0;
                    this.incoming = "";
                    this.outgoing = "";
                    this.address = null;
                    this.state = "IDLE";
                    // Force neighbor update
                    neighborhood.timer = 0;
                    this.timer = 0;
                    break;
                case NEWADDRESS:
                case NOINTERFACE:
                case CLOSECONN:
                default:
                    this.polling = 0;
                    this.state = "EXIT";
                    this.timer = 0;
                    break;
            }
            break;
        }
        case "INCOMING":
        {
            this.incoming = "";
            this.outgoing = buildMessage(CMD_VERSION, myipv4address, 1, VERSION) + buildTargettedSyncMessage(this.interface);
            this.state = "CONNECTED_INCOMING";
            this.polling = POLLIN|POLLOUT|POLLRDHUP;
            // Fall through
        }
        case "CONNECTED_INCOMING":
        {
            switch (event) {
                case POLLIN:
                    call(processRequest, this);
                    break;
                case POLLOUT:
                case POLLIN|POLLOUT:
                    const sent = this.connection.send(this.outgoing);
                    if (sent == length(this.outgoing)) {
                        this.outgoing = "";
                        this.polling &= ~POLLOUT;
                    }
                    else if (send !== null) {
                        this.outgoing = substr(this.outgoing, sent);
                    }
                    break;
                case POLLRDHUP:
                case POLLRDHUP|POLLIN:
                case POLLRDHUP|POLLOUT:
                case POLLRDHUP|POLLIN|POLLOUT:
                    // Force neighbor update
                    neighborhood.timer = 0;
                    // Fall through
                case NEWADDRESS:
                case CLOSECONN:
                case NOINTERFACE:
                default:
                    this.state = "EXIT";
                    this.polling = 0;
                    this.timer = 0;
                    break;
            }
            break;
        }
        case "EXIT":
        default:
        {
            this.state = "CLOSED";
            if (this.connection) {
                this.connection.close();
                this.connection = null;
            }
            delete channels[this.id];
            const iface = interfaces[this.interface];
            if (iface.primary === this) {
                if (iface.secondary) {
                    this.primary = this.secondary;
                    this.secondary = null;
                }
                else {
                    iface.primary = null;
                }
            }
            if (iface.secondary === this) {
                iface.secondary = null;
            }
            break;
        }
    }
}

//
// Create a new channel to manage the socket. The channel may be for an incoming
// comnnection, or for one we're initiating.
//
function createChannel(initialstate, connection, polling, timer, process) {
    DEBUG && print(`createChannel: state ${initialstate} connection ${connection} polling ${polling} timer ${timer}\n`);
    const channel = {
        id: channelId++,
        state: initialstate,
        connection: connection,
        polling: polling,
        timer: timer
    };
    if (!process) {
        process = channelProcess;
    }
    channel.process = (event) => call(process, channel, null, event),
    channels[channel.id] = channel;
    return channel;
}

//
// Process manager commands.
// this: channel
//
function managerProcess(event) {
    switch (this.state) {
        case "INCOMING":
            this.connection.send(`AREDNLink ${VERSION}\n`);
            this.state = "READING";
            this.polling &= ~POLLOUT;
            // Fall through
        case "READING":
        default:
        {
            if (event & POLLRDHUP) {
                this.state = "CLOSED";
                this.polling = 0;
                this.connection.close();
                delete channels[this.id];
            }
            else if (event & POLLIN) {
                const cmds = split(this.connection.recv(), "\n");
                for (let i = 0; i < length(cmds) && this.state != "CLOSED"; i++) {
                    const cv = split(trim(cmds[i]), " ", 2);
                    switch (cv[0]) {
                        case "upload-names":
                        {
                            const data = fs.readfile(trim(cv[1]));
                            if (!data) {
                                this.connection.send("bad file\n");
                            }
                            else {
                                const path = `${ROOT_DIR_NAMES}${myipv4address}`;
                                const old = fs.readfile(path);
                                if (old != data) {
                                    fs.writefile(path, data);
                                    sendMsgToAll(buildMessage(CMD_UPDATE_NAMES, myipv4address, HOP_DEFAULT, data));
                                    this.connection.send(old ? "ok updated\n" : "ok new\n");
                                }
                                else {
                                    this.connection.send("ok nochange\n");
                                }
                            }
                            break;
                        }
                        case "upload-services":
                        {
                            const data = fs.readfile(trim(cv[1]));
                            if (!data) {
                                this.connection.send("bad file\n");
                            }
                            else {
                                const path = `${ROOT_DIR_SERVICES}${myipv4address}`;
                                const old = fs.readfile(path);
                                if (old != data) {
                                    fs.writefile(path, data);
                                    sendMsgToAll(buildMessage(CMD_UPDATE_SERVICES, myipv4address, HOP_DEFAULT, data));
                                    this.connection.send(old ? "ok updated\n" : "ok new\n");
                                }
                                else {
                                    this.connection.send("ok nochange\n");
                                }
                            }
                            break;
                        }
                        case "force-update":
                        {
                            const n = fs.readfile(`${ROOT_DIR_NAMES}${myipv4address}`);
                            if (n) {
                                sendMsgToAll(buildMessage(CMD_UPDATE_NAMES, myipv4address, HOP_DEFAULT, n));
                            }
                            const s = fs.readfile(`${ROOT_DIR_SERVICES}${myipv4address}`);
                            if (s) {
                                sendMsgToAll(buildMessage(CMD_UPDATE_SERVICES, myipv4address, HOP_DEFAULT, s));
                            }
                            this.connection.send("ok\n");
                            break;
                        }
                        case "quit":
                            this.state = "CLOSED";
                            this.polling = 0;
                            this.connection.close();
                            delete channels[this.id];
                            break;
                        case "":
                            break;
                        default:
                            this.connection.send("bad command\n");
                            break;
                    }
                }
            }
            break;
        }
    }
}

//
// Monitor the neighborhood
//
function neighborhoodProcess(event) {
    DEBUG && print("neighborhoodProcess\n");
    const ifaces = babel.getInterfaces();
    const oldinterfaces = interfaces;
    interfaces = {};
    for (let i = 0; i < length(ifaces); i++) {
        const iface = ifaces[i];
        const name = iface.interface;
        if (name === "br-nomesh") {
            // Ignore interfaces which cannot have neighbors
        }
        else if (oldinterfaces[name]) {
            interfaces[name] = oldinterfaces[name];
            delete oldinterfaces[name];
        }
        else {
            interfaces[name] = { address: iface.ipv6address, primary: null, secondary: null };
        }
    }
    for (let name in oldinterfaces) {
        const iface = oldinterfaces[name];
        if (iface.primary) {
            iface.primary.timer = null;
            iface.primary.process(NOINTERFACE);
        }
        if (iface.secondary) {
            iface.secondary.timer = null;
            iface.secondary.process(NOINTERFACE);
        }
    }

    const neighbors = babel.getNeighbors();
    const ifacea = {};
    const now = clock(true)[0];
    for (let i = 0; i < length(neighbors); i++) {
        const n = neighbors[i];
        const gray = graylist[n.ipv6address];
        if (!gray || gray.timer < now) {
            ifacea[n.interface] = bestAddress(ifacea[n.interface], n.ipv6address);
        }
    }
    for (let name in ifacea) {
        const address = ifacea[name];
        const iface = interfaces[name];
        if (!(iface.primary && iface.secondary)) {
            if (iface.primary && iface.primary.address !== address) {
                if (iface.primary.state === "IDLE") {
                    iface.primary.address = address;
                    iface.primary.process(NEWADDRESS);
                }
                else {
                    iface.secondary = iface.primary;
                    iface.primary = null;
                }
            }
            if (!iface.primary) {
                const channel = createChannel("IDLE", null, 0, 0);
                channel.interface = name;
                channel.myaddress = iface.address;
                channel.address = address;
                iface.primary = channel;
                channel.process(NEWADDRESS);
            }
        }
    }

    this.timer = when(NEIGHBORHOOD_POLL);
}

//
// Monitor Babel route changes.
//
function routeProcess(event) {
    DEBUG && print("routeProcess\n");
    const broutes = babel.getHostRoutes();

    const oldr = hostroutes;
    const newr = {};
    hostroutes = {};
    for (let i = length(broutes) - 1; i >= 0; i--) {
        const route = broutes[i];
        const dst = route.dst;
        const iface = route.iface;
        hostroutes[dst] = iface;
        if (oldr[dst]) {
            delete oldr[dst];
        }
        else {
            // Build the sync message payloads as we go
            const addr = iptoarr(dst);
            if (!newr[iface]) {
                newr[iface] = chr(addr[0], addr[1], addr[2], addr[3]);
            }
            else {
                newr[iface] += chr(addr[0], addr[1], addr[2], addr[3]);
            }
        }
    }

    DEBUG && printf(`--- current ${hostroutes}\n--- old ${oldr}\n--- new ${newr}\n`);

    // Remove any data we no longer need
    for (let ip in oldr) {
        fs.unlink(`${ROOT_DIR_NAMES}${ip}`);
        fs.unlink(`${ROOT_DIR_SERVICES}${ip}`);
    }

    // Sync our neighbors for information about the new routes
    for (let id in channels) {
        const channel = channels[id];
        const sync = newr[channel.interface];
        if (sync && (channel.state === "CONNECTED" || channel.state === "CONNECTED_INCOMING")) {
            channel.outgoing += buildMessage(CMD_SYNC, myipv4address, 1, sync);
            channel.polling |= POLLOUT;
        }
    }

    this.timer = when(ROUTE_POLL);
}

//
// Our main socket process handles incoming requests, accepts them
// then creates a channel to manage them.
//
function mainProcess(event) {
    if (event & POLLIN) {
        const address = {};
        const channel = createChannel("INCOMING", main.accept(address, socket.SOCK_NONBLOCK), POLLIN|POLLRDHUP, null);
        channel.interface = address.interface;
        channel.address = address.address;
        setupConnection(channel.connection);
    }
}

//
// Our mgr socket profcess handles incoming manage requests, accepts them
// then creates a channel to handle the incoming manager calls.
//
function mgrProcess(event) {
    if (event & POLLIN) {
        createChannel("INCOMING", mgr.accept(), POLLIN|POLLOUT|POLLRDHUP, null, managerProcess);
    }
}

//
// Work out what to poll and poll it.
// NOTE: Because socket.poll takes a list of arguments and not an array, and because there
// is no fn.apply(...) method, we use 'loadstring' to build our own. We keep it around and
// only rebuild it when the argument count changes. Maybe I'm missing an easier way to do this?
//
function pollWorkers() {
    const workers = [];
    let timeout = 24 * 60 * 60; // 1 day
    const now = clock(true)[0];
    for (let id in channels) {
        const channel = channels[id];
        if (channel.timer !== null) {
            timeout = min(timeout, channel.timer - now);
        }
        if (channel.connection && channel.polling) {
            push(workers, [ channel.connection, channel.polling, channel ]);
        }
        else if (channel.timer === null) {
            print(`ERROR: Worker blocked without timer or active socket: ${channel}\n`);
        }
    }
    if (length(workers) !== poller.len) {
        poller.len = length(workers);
        let p = "import * as socket from 'socket';return function(t,w){ return socket.poll(t";
        for (let count = 0; count < poller.len; count++) {
            p += `,w[${count}]`;
        }
        p += ");}";
        poller.fn = loadstring(p, { raw_mode: true })();
    }
    timeout = max(0, timeout);
    DEBUG && printf(`POLL timeout ${timeout} workers ${workers}\n`);
    return poller.fn(1000 * timeout, workers) || [];
}

//
// Signals
//
signal("SIGINT", _ => {
    exiting = true;
});
signal("SIGTERM", _ => {
    exiting = true;
});

//
// Create data directores and empty them.
//
system(`mkdir -p ${ROOT_DIR_NAMES}`);
system(`rm -f ${ROOT_DIR_NAMES}*`);
system(`mkdir -p ${ROOT_DIR_SERVICES}`);
system(`rm -f ${ROOT_DIR_SERVICES}*`);

//
// Start connecting
//
createChannel("MAIN", main, POLLIN, null, mainProcess);
createChannel("MGR", mgr, POLLIN, null, mgrProcess);
createChannel("ROUTES", null, 0, 0, routeProcess);
neighborhood = createChannel("NEIGHBORHOOD", null, 0, 0, neighborhoodProcess);

//
// Run until exit
//
while (!exiting) {
    // Poll for any sockets which we can dispatch
    const events = pollWorkers();
    DEBUG && printf("Dispatching %s\n", events);
    for (let i = 0; i < length(events); i++) {
        const event = events[i];
        if (event[1]) {
            event[2].timer = null;
            event[2].process(event[1]);
        }
    }
    // Check for expired timers
    const now = clock(true)[0];
    for (let id in channels) {
        const channel = channels[id];
        if (channel.timer !== null && channel.timer <= now) {
            channel.timer = null;
            channel.process(POLLTIMER);
        }
    }
}

DEBUG && print("Exiting\n");
//
// Tidy up connections on the way out
//
main.close();
for (let id in channels) {
    if (channels[id].connection) {
        channels[id].connection.close();
    }
}
mgr.close();
